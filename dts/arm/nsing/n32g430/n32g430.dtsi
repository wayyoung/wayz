#include <arm/armv7-m.dtsi>
#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/adc/adc.h>
#include <zephyr/dt-bindings/i2c/i2c.h>
#include <zephyr/dt-bindings/clock/n32g430-clock.h>
#include <freq.h>

/ {

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-m4f";
			reg = <0>;
		};
	};

	sram0: memory@20000000 {
		compatible = "mmio-sram";
	};

	soc {

		rcc: rcc@40021000 {
			compatible = "nsing,n32-rcc";
			clocks-controller;
			#clock-cells = <1>;
			reg = <0x40021000 0x400>;
			status = "okay";
			
			prst: reset-controller {
				compatible = "nsing,n32-prst";
				#reset-cells = <1>;
				status = "okay";
			};

		};


		flash: flash-controller@40022000 {
			compatible = "nsing,n32-flash-controller";
			reg = <0x40022000 0x400>;
			interrupts = <4 0>;
			#address-cells = <1>;
			#size-cells = <1>;

			flash0: flash@8000000 {
				reg = <0x08000000 0x10000>;
				compatible = "soc-nv-flash";
				write-block-size = <4>;
				erase-block-size = <2048>;
			};
		};

		i2c1: i2c@40005400 {
			compatible = "nsing,n32-i2c";
			reg = <0x40005400 0x400>;
			#address-cells = <1>;
			#size-cells = <0>;
			interrupts = <31 0>, <32 0>;
			interrupt-names = "event", "error";
			clock-frequency = <I2C_BITRATE_STANDARD>;
			clocks = <&rcc N32_CLOCK_I2C1>;
			resets = <&prst N32_CLOCK_I2C1>;
			status = "disabled";
		};

		i2c2: i2c@40005800 {
			compatible = "nsing,n32-i2c";
			reg = <0x40005800 0x400>;
			#address-cells = <1>;
			#size-cells = <0>;
			interrupts = <33 0>, <34 0>;
			interrupt-names = "event", "error";
			clock-frequency = <I2C_BITRATE_STANDARD>;
			clocks = <&rcc N32_CLOCK_I2C2>;
			resets = <&prst N32_CLOCK_I2C2>;
			status = "disabled";
		};

		pinctrl: pin-controller@40023400 {
			compatible = "nsing,n32-pinctrl";
			reg = <0x40023400 0x1000>;
			#address-cells = <1>;
			#size-cells = <1>;
			status = "okay";

			gpioa: gpio@40023400 {
				compatible = "nationstech,n32-gpio";
				gpio-controller;
				#gpio-cells = <2>;
				reg = <0x40023400 0x400>;
				clocks = <&rcc N32_CLOCK_GPIOA>;
				status = "okay";
			};

			gpiob: gpio@40023800 {
				compatible = "nationstech,n32-gpio";
				gpio-controller;
				#gpio-cells = <2>;
				reg = <0x40023800 0x400>;
				clocks = <&rcc N32_CLOCK_GPIOB>;
				status = "okay";
			};

			gpioc: gpio@40023C00 {
				compatible = "nationstech,n32-gpio";
				gpio-controller;
				#gpio-cells = <2>;
				reg = <0x40023C00 0x400>;
				clocks = <&rcc N32_CLOCK_GPIOC>;
				status = "okay";
			};

			gpiod: gpio@40024000 {
				compatible = "nationstech,n32-gpio";
				gpio-controller;
				#gpio-cells = <2>;
				reg = <0x40024000 0x400>;
				clocks = <&rcc N32_CLOCK_GPIOD>;
				status = "okay";
			};

		};

		exti: interrupt-controller@40010400 {
			compatible = "nationstech,n32-exti";
			interrupt-controller;
			#interrupt-cells = <1>;
			reg = <0x40010400 0x400>;
			num-lines = <24>;
			interrupts = <6 0>, <7 0>, <8 0>, <9 0>, <10 0>, <22 0>,
				     <39 0>;
			interrupt-names = "line0", "line1", "line2",
					  "line3", "line4", "line5-9",
					  "line10-15";
			status = "okay";
		};

		usart1: usart1@40013800 {
			compatible = "nationstech,n32-uart";
			reg = <0x40013800 0x400>;
			clocks = <&rcc N32_CLOCK_USART1>;
			interrupts = <37 0>;
			current-speed = <115200>;
			status = "disabled";
		};

		usart2: usart2@40004400 {
			compatible = "nationstech,n32-uart";
			reg = <0x40004400 0x400>;
			clocks = <&rcc N32_CLOCK_USART2>;
			interrupts = <38 0>;
			current-speed = <115200>;
			status = "disabled";
		};

		uart3: uart6@40015000 {
			compatible = "nationstech,n32-uart";
			reg = <0x40015000 0x400>;
			clocks = <&rcc N32_CLOCK_UART6>;
			interrupts = <53 0>;
			current-speed = <115200>;
			status = "disabled";
		};

		uart4: uart@40015400 {
			compatible = "nationstech,n32-uart";
			reg = <0x40015400 0x400>;
			clocks = <&rcc N32_CLOCK_UART7>;
			interrupts = <75 0>;
			current-speed = <115200>;
			status = "disabled";
		};

		timer1: timer@40012c00 {
			compatible = "nationstech,n32-timer";
			reg = <0x40012c00 0x400>;
			interrupts = <24 0>, <25 0>, <26 0>, <27 0>;
			interrupt-names = "brk", "up", "trgcom", "cc";
			clocks = <&rcc N32_CLOCK_TIM1>;
			resets = <&prst N32_CLOCK_TIM1>;
			advanced;
			channels = <6>;
			status = "disabled";

			pwm1 {
				compatible = "nationstech,n32-pwm";
				status = "disabled";
				#pwm-cells = <3>;
			};
		};

		timer8: timer@40013400 {
			compatible = "nationstech,n32-timer";
			reg = <0x40013400 0x400>;
			interrupts = <43 0>, <44 0>, <45 0>, <46 0>;
			interrupt-names = "brk", "up", "trgcom", "cc";
			clocks = <&rcc N32_CLOCK_TIM8>;
			resets = <&prst N32_CLOCK_TIM8>;
			advanced;
			channels = <6>;
			status = "disabled";

			pwm8 {
				compatible = "nationstech,n32-pwm";
				status = "disabled";
				#pwm-cells = <3>;
			};
		};

		timer2: timer@40000000 {
			compatible = "nationstech,n32-timer";
			reg = <0x40000000 0x400>;
			interrupts = <28 0>;
			interrupt-names = "global";
			clocks = <&rcc N32_CLOCK_TIM2>;
			resets = <&prst N32_CLOCK_TIM2>;
			channels = <4>;
			status = "disabled";

			pwm2 {
				compatible = "nationstech,n32-pwm";
				status = "disabled";
				#pwm-cells = <3>;
			};
		};

		timer3: timer@40000400 {
			compatible = "nationstech,n32-timer";
			reg = <0x40000400 0x400>;
			interrupts = <29 0>;
			interrupt-names = "global";
			clocks = <&rcc N32_CLOCK_TIM3>;
			resets = <&prst N32_CLOCK_TIM3>;
			channels = <4>;
			status = "disabled";

			pwm3 {
				compatible = "nationstech,n32-pwm";
				status = "disabled";
				#pwm-cells = <3>;
			};
		};


		timer4: timer@40000800 {
			compatible = "nationstech,n32-timer";
			reg = <0x40000800 0x400>;
			interrupts = <30 0>;
			interrupt-names = "global";
			clocks = <&rcc N32_CLOCK_TIM4>;
			resets = <&prst N32_CLOCK_TIM4>;
			channels = <4>;
			status = "disabled";

			pwm4 {
				compatible = "nationstech,n32-pwm";
				status = "disabled";
				#pwm-cells = <3>;
			};
		};

		timer5: timer@40000c00 {
			compatible = "nationstech,n32-timer";
			reg = <0x40000c00 0x400>;
			interrupts = <50 0>;
			interrupt-names = "global";
			clocks = <&rcc N32_CLOCK_TIM5>;
			resets = <&prst N32_CLOCK_TIM5>;
			channels = <4>;
			status = "disabled";

			pwm5 {
				compatible = "nationstech,n32-pwm";
				status = "disabled";
				#pwm-cells = <3>;
			};
		};

		adc1: adc@40020800 {
			compatible = "nationstech,n32-adc";
			reg = <0x40020800 0x400>;
			interrupts = <18 0>;
			clocks = <&rcc N32_CLOCK_ADC1>;
			resets = <&prst N32_CLOCK_ADC1>;
			channels = <16>;
			status = "disabled";
			#io-channel-cells = <1>;
		};

		adc2: adc@40020c00 {
			compatible = "nationstech,n32-adc";
			reg = <0x40020c00 0x400>;
			interrupts = <18 0>;
			clocks = <&rcc N32_CLOCK_ADC2>;
			resets = <&prst N32_CLOCK_ADC2>;
			channels = <16>;
			status = "disabled";
			#io-channel-cells = <1>;
		};		



	};
};

&nvic {
	arm,num-irq-priority-bits = <4>;
};
